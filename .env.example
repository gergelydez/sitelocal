# --- Notificare prin email (unde primești lead-urile) ---
# Contul Gmail din care se trimite emailul de notificare
GMAIL_USER=

# Parolă de aplicație Gmail (NU parola normală de cont) — vezi README pentru pași
GMAIL_APP_PASSWORD=

# Emailul tău, unde vrei să primești notificarea de lead nou
NOTIFY_EMAIL=

# --- Meta Pixel + Conversions API ---
# Meta Pixel ID — găsești în Events Manager > Data Sources > Pixel-ul tău
# Acesta e PUBLIC (merge în browser), de asta are prefixul NEXT_PUBLIC_
# Opțional: codul are deja ID-ul 1983304235646415 hardcodat ca fallback,
# dar poți suprascrie aici dacă schimbi contul de Ads.
NEXT_PUBLIC_META_PIXEL_ID=

# Același Pixel ID, dar folosit server-side pentru Conversions API
META_PIXEL_ID=

# Access Token pentru Conversions API — Events Manager > Setări > Conversions API > Generează token
# ATENȚIE: acesta e SECRET. Nu-l pune niciodată în cod, doar în variabilele de mediu din Vercel.
# Fără el, evenimentele Lead/Contact/ViewContent merg doar prin Pixel-ul din browser,
# nu și prin Conversions API (server) — vezi README pentru de ce contează amândouă.
META_CAPI_ACCESS_TOKEN=
